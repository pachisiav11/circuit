# Copy this file to a file named exactly  .env  (same folder) and paste your key.
# NEVER commit .env — it is git-ignored on purpose.

OPENAI_API_KEY=sk-your-key-here

# Optional: change the server port (default 8787)
# PORT=8787

# --- Python AI Strategist (ai_server.py) ---
# Model used by the AI Strategist hint/taunt endpoint.
OPENAI_MODEL=gpt-5.4-nano
# Optional: change the AI Strategist server port (default 5001)
# AI_PORT=5001
